<?xml version="1.0" encoding="UTF-8"?>

<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides"
           xsi:type="MailApp">

  <Id>fec53ef9-3b81-47f3-b01f-5a72cbcaf396</Id>

  <Version>1.0.0.11</Version>

  <ProviderName>Signature Clinic</ProviderName>

  <DefaultLocale>en-GB</DefaultLocale>

  <DisplayName DefaultValue="External Warning"/>

  <Description DefaultValue="Review external recipients before sending email."/>

  <IconUrl DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

  <HighResolutionIconUrl DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

  <SupportUrl DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net"/>

  <AppDomains>
    <AppDomain>https://green-glacier-0a2034903.7.azurestaticapps.net</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/index.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs"
          ItemType="Message"
          FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>

      <Host xsi:type="MailHost">

        <DesktopFormFactor>

          <ExtensionPoint xsi:type="MessageComposeCommandSurface">

            <OfficeTab id="TabDefault">

              <Group id="msgComposeCmdGroup">

                <Label resid="GroupLabel"/>

                <Control xsi:type="Button"
                         id="msgComposeOpenPaneButton">

                  <Label resid="TaskpaneButton.Label"/>

                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>

                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>

                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>

                </Control>

              </Group>

            </OfficeTab>

          </ExtensionPoint>

        </DesktopFormFactor>

      </Host>

    </Hosts>

    <Resources>

      <bt:Images>

        <bt:Image id="Icon.16x16"
                  DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

        <bt:Image id="Icon.32x32"
                  DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

        <bt:Image id="Icon.80x80"
                  DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

      </bt:Images>

      <bt:Urls>

        <bt:Url id="Taskpane.Url"
                DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/index.html"/>

      </bt:Urls>

      <bt:ShortStrings>

        <bt:String id="GroupLabel"
                   DefaultValue="External Warning"/>

        <bt:String id="TaskpaneButton.Label"
                   DefaultValue="Check Recipients"/>

      </bt:ShortStrings>

      <bt:LongStrings>

        <bt:String id="TaskpaneButton.Tooltip"
                   DefaultValue="Review external recipients before sending."/>

      </bt:LongStrings>

    </Resources>

  </VersionOverrides>

</OfficeApp>
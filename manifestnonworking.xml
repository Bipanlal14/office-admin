<?xml version="1.0" encoding="UTF-8"?>

<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
  xsi:type="MailApp">

  <Id>c1d5a4b0-8b52-4b5c-9f1c-999988887777</Id>

  <Version>1.0.0.1</Version>

  <ProviderName>Signature Clinic</ProviderName>

  <DefaultLocale>en-GB</DefaultLocale>

  <DisplayName DefaultValue="External Warning"/>

  <Description DefaultValue="Warn users before sending external emails."/>

  <IconUrl DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

  <HighResolutionIconUrl DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

  <SupportUrl DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net"/>

  <AppDomains>
    <AppDomain>https://green-glacier-0a2034903.7.azurestaticapps.net</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/index.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs"
          ItemType="Message"
          FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
    xsi:type="VersionOverridesV1_1">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>

      <Host xsi:type="MailHost">

        <DesktopFormFactor>

          <ExtensionPoint xsi:type="MessageComposeCommandSurface">

            <OfficeTab id="TabDefault">

              <Group id="msgComposeGroup">

                <Label resid="groupLabel"/>

                <Control xsi:type="Button"
                         id="openPaneButton">

                  <Label resid="buttonLabel"/>

                  <Supertip>
                    <Title resid="buttonLabel"/>
                    <Description resid="buttonDesc"/>
                  </Supertip>

                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>

                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>

                </Control>

              </Group>

            </OfficeTab>

          </ExtensionPoint>

        </DesktopFormFactor>

      </Host>

    </Hosts>

    <Resources>

      <bt:Images>

        <bt:Image id="icon16"
          DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

        <bt:Image id="icon32"
          DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

        <bt:Image id="icon80"
          DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/assets/logo.png"/>

      </bt:Images>

      <bt:Urls>

        <bt:Url id="taskpaneUrl"
          DefaultValue="https://green-glacier-0a2034903.7.azurestaticapps.net/index.html"/>

      </bt:Urls>

      <bt:ShortStrings>

        <bt:String id="groupLabel"
          DefaultValue="External Warning"/>

        <bt:String id="buttonLabel"
          DefaultValue="Check Recipients"/>

      </bt:ShortStrings>

      <bt:LongStrings>

        <bt:String id="buttonDesc"
          DefaultValue="Warn before sending external email."/>

      </bt:LongStrings>

    </Resources>

  </VersionOverrides>

</OfficeApp>